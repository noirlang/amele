#!/bin/sh
APPDIR="$(dirname "$(readlink -f "$0")")"

export AMELE_UI_ROOT="${AMELE_UI_ROOT:-$APPDIR/usr/share/amele/ui}"
export AMELE_APP_ICON="${AMELE_APP_ICON:-$APPDIR/usr/share/icons/hicolor/256x256/apps/amele.png}"
export AMELE_VOLATILITY_WORKER_PATH="${AMELE_VOLATILITY_WORKER_PATH:-$APPDIR/usr/share/amele/tools/amele_volatility_worker.py}"
export AMELE_VOLATILITY3_PATH="${AMELE_VOLATILITY3_PATH:-$APPDIR/usr/share/amele/vendor/volatility3}"

WEBKIT_BUNDLE_DIR="$APPDIR/usr/lib/x86_64-linux-gnu/webkit2gtk-4.1"
if [ -d "$WEBKIT_BUNDLE_DIR" ]; then
  export WEBKIT_EXEC_PATH="${WEBKIT_EXEC_PATH:-$WEBKIT_BUNDLE_DIR}"
  export WEBKIT_INJECTED_BUNDLE_PATH="${WEBKIT_INJECTED_BUNDLE_PATH:-$WEBKIT_BUNDLE_DIR/injected-bundle}"
fi

run_ui() {
  cd "$APPDIR" || exit 1
  exec "$APPDIR/usr/bin/amele-forensic-tool" ui "$@"
}

case "${1:-}" in
  "" )
    run_ui
    ;;
  ui )
    shift
    run_ui "$@"
    ;;
  settings-default|hash|disk-list|local-image|local-ram|remote-ram|image-analyze|ram-summary|ram-strings|ram-carve|ram-processes|adb-status|android-adb-status|android-devices|android-profile|android-logical|android-filesystem|android-ram|disk-list-helper|image-helper|ram-helper|avml-install-helper|winpmem-install-helper|mount-helper|disk-size|verify|remote-disks|remote-image|remote-tool-check|ram-status|wireguard-config|ui-browser )
    exec "$APPDIR/usr/bin/amele-forensic-tool" "$@"
    ;;
  * )
    run_ui "$@"
    ;;
esac
